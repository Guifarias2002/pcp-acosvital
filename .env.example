# Banco de Dados (Supabase Connection Pooler)
DB_HOST=aws-0-xx-east-1.pooler.supabase.com
DB_NAME=postgres
DB_USER=postgres.<project-id>
DB_PASSWORD=<sua-senha>
DB_PORT=6543

# JWT
JWT_SECRET=<chave-secreta-longa-e-aleatoria>

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Cron (backup diário)
CRON_SECRET=<chave-secreta-para-cron>

# URL pública do app (usado no trigger manual de backup)
NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app
